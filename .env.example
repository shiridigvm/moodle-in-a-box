# Database
DB_NAME=moodle
DB_USER=moodle
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# Moodle
MOODLE_WWWROOT=http://localhost
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
MOODLE_ADMIN_EMAIL=admin@techcorp.example.com
MOODLE_FULLNAME=TechCorp Academy
MOODLE_SHORTNAME=TechCorp

# Ports (local dev)
HTTP_PORT=80
HTTPS_PORT=443

# Production domain (used by docker-compose.prod.yml)
DOMAIN=learn.techcorp.example.com
